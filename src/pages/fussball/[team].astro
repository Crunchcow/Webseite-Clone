---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllTeams, type TeamData } from '../../lib/trainerData';

interface TeamPageContent {
  intro: string;
  photo?: string;        // Pfad zum Mannschaftsfoto, z. B. /assets/img/1-herren.jpg
  photoAlt?: string;
  league?: string;
  training?: string;
  venue?: string;
  links: Array<{ label: string; href: string }>;
  news: Array<{ title: string; excerpt: string; href: string }>;
}

export function getStaticPaths() {
  return getAllTeams().map((team) => ({
    params: { team: team.slug },
    props: { team },
  }));
}

const { team } = Astro.props as { team: TeamData };
const title = `${team.name} - Fußball | SV Westfalia Osterwick`;

