---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Partner & Sponsoren - SV Westfalia Osterwick">
  <Header />

  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center mb-16">
        <h1 class="text-5xl font-black text-anthrazit mb-6">Unsere Partner</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Ein herzliches Dankeschön an alle Unternehmen und Förderer, die den Sport beim 
          SV Westfalia Osterwick mit ihrer Leidenschaft und Unterstützung möglich machen.
        </p>
      </div>

      <section class="mb-20">
        <h2 class="text-center text-westfalia-red font-bold uppercase tracking-widest mb-12 text-sm">Hauptsponsor</h2>
        <div class="flex justify-center">
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-12 rounded-3xl shadow-lg hover:shadow-2xl transition-all border border-gray-100 group max-w-md">
              <div class="h-32 w-64 bg-gradient-to-br from-gray-100 to-gray-50 rounded-xl flex items-center justify-center text-gray-400 font-bold text-lg group-hover:from-gray-50 group-hover:to-white transition-colors">
                  🏢 Ihr Logo hier
              </div>
              <p class="text-center text-sm text-gray-500 mt-4">Interessiert? Kontaktieren Sie uns!</p>
          </a>
        </div>
      </section>

      <hr class="border-gray-200 mb-20">

      <section class="mb-20">
        <h2 class="text-center text-gray-500 font-bold uppercase tracking-widest mb-12 text-sm">Premium Partner</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-lg transition-all border border-gray-100 flex items-center justify-center group">
              <div class="h-20 w-full bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg flex items-center justify-center text-gray-400 font-bold text-sm group-hover:from-gray-100 group-hover:to-gray-50 transition-colors">
                  Partner Logo
              </div>
          </a>
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-lg transition-all border border-gray-100 flex items-center justify-center group">
              <div class="h-20 w-full bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg flex items-center justify-center text-gray-400 font-bold text-sm group-hover:from-gray-100 group-hover:to-gray-50 transition-colors">
                  Partner Logo
              </div>
          </a>
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-lg transition-all border border-gray-100 flex items-center justify-center group">
              <div class="h-20 w-full bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg flex items-center justify-center text-gray-400 font-bold text-sm group-hover:from-gray-100 group-hover:to-gray-50 transition-colors">
                  Partner Logo
              </div>
          </a>
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-lg transition-all border border-gray-100 flex items-center justify-center group">
              <div class="h-20 w-full bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg flex items-center justify-center text-gray-400 font-bold text-sm group-hover:from-gray-100 group-hover:to-gray-50 transition-colors">
                  Partner Logo
              </div>
          </a>
        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-center text-gray-400 font-bold uppercase tracking-widest mb-12 text-sm">Partner & Förderer</h2>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition-all border border-gray-50 flex items-center justify-center group aspect-square">
              <div class="text-gray-300 font-bold text-xs text-center group-hover:text-gray-400 transition-colors">
                  Förderer
              </div>
          </a>
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition-all border border-gray-50 flex items-center justify-center group aspect-square">
              <div class="text-gray-300 font-bold text-xs text-center group-hover:text-gray-400 transition-colors">
                  Förderer
              </div>
          </a>
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition-all border border-gray-50 flex items-center justify-center group aspect-square">
              <div class="text-gray-300 font-bold text-xs text-center group-hover:text-gray-400 transition-colors">
                  Förderer
              </div>
          </a>
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition-all border border-gray-50 flex items-center justify-center group aspect-square">
              <div class="text-gray-300 font-bold text-xs text-center group-hover:text-gray-400 transition-colors">
                  Förderer
              </div>
          </a>
          <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition-all border border-gray-50 flex items-center justify-center group aspect-square">
              <div class="text-gray-300 font-bold text-xs text-center group-hover:text-gray-400 transition-colors">
                  Förderer
              </div>
          </a>
        </div>
      </section>

      <div class="bg-gradient-to-r from-anthrazit to-slate-800 rounded-3xl p-8 md:p-12 text-center text-white relative overflow-hidden">
        <div class="absolute -bottom-10 -right-10 text-[15rem] opacity-5 rotate-12">⚽</div>
        <div class="relative z-10">
            <h3 class="text-3xl md:text-4xl font-black mb-4">Werde auch du Partner!</h3>
            <p class="text-gray-300 mb-8 max-w-2xl mx-auto text-lg">
              Unterstützen Sie den Sport in Rosendahl und profitieren Sie von der Reichweite unseres über 1.000-köpfigen Vereins.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="mailto:sponsoring@westfalia-osterwick.de" class="bg-westfalia-red hover:bg-red-700 text-white px-8 py-4 rounded-2xl font-bold transition-all inline-block shadow-lg shadow-red-900/50">
                Jetzt Kontakt aufnehmen →
              </a>
              <a href="/vorstand" class="bg-white hover:bg-gray-100 text-anthrazit font-bold px-8 py-4 rounded-2xl transition-all inline-block">
                Zum Vorstand
              </a>
            </div>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
