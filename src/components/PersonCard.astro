---
interface Props {
  initials: string;
  /** Tailwind-Farbklassen, z.B. "from-westfalia-red" */
  gradientFrom: string;
  /** Tailwind-Farbklassen, z.B. "to-red-700" */
  gradientTo: string;
  name: string;
  role: string;
  email?: string;
  phone?: string;
  /** Kompaktere Darstellung (kleinerer Avatar, weniger Padding) */
  compact?: boolean;
}

const { initials, gradientFrom, gradientTo, name, role, email, phone, compact = false } = Astro.props;

const avatarSize  = compact ? 'w-16 h-16 text-lg' : 'w-20 h-20 text-xl';
const padding     = compact ? 'p-5' : 'p-6';
const nameSize    = compact ? 'text-sm' : 'text-lg';
const hasContact  = email || phone;
---

<div class={`bg-white rounded-xl ${padding} shadow-sm border border-gray-100 flex flex-col items-center text-center transition-all duration-300 hover:shadow-lg hover:border-westfalia-red/20 hover:-translate-y-1`}>
  <div class={`${avatarSize} bg-gradient-to-br ${gradientFrom} ${gradientTo} rounded-full mb-4 flex items-center justify-center text-white font-bold`}>
    {initials}
  </div>
  <h3 class={`font-bold text-anthrazit ${nameSize}`}>{name}</h3>
  <span class="text-westfalia-red font-bold text-xs uppercase tracking-wider mt-1 mb-4">{role}</span>

  {hasContact ? (
    <div class="w-full space-y-2 mt-auto">
      {phone && (
        <a
          href={`tel:${phone.replace(/\s/g, '')}`}
          class="w-full py-1.5 rounded-lg bg-gray-50 border border-gray-200 text-xs font-semibold text-gray-700 hover:bg-gray-100 transition-colors flex items-center justify-center gap-1"
        >
          📞 {phone}
        </a>
      )}
      {email && (
        <a
          href={`mailto:${email}`}
          class="w-full py-1.5 rounded-lg border border-gray-200 text-xs font-semibold text-gray-600 hover:bg-westfalia-red hover:text-white hover:border-westfalia-red transition-colors flex items-center justify-center gap-2"
        >
          ✉️ E-Mail
        </a>
      )}
    </div>
  ) : (
    <span class="w-full py-1.5 rounded-lg bg-gray-50 border border-gray-100 text-xs text-gray-400 mt-auto">
      Kein Direktkontakt
    </span>
  )}
</div>
